<DispatcherCard Class="@Class">
    <MudStack Spacing="1">
        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
            @Title
        </MudText>

        <MudText Typo="Typo.h5" Color="@ValueColor">
            @Value
        </MudText>

        @if (!string.IsNullOrWhiteSpace(ChipText))
        {
            <DispatcherStatusChip Text="@ChipText"
                                  Color="@ChipColor"
                                  Size="Size.Small" />
        }

        @if (!string.IsNullOrWhiteSpace(Description))
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @Description
            </MudText>
        }
    </MudStack>
</DispatcherCard>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Value { get; set; } = "Н/Д";

    [Parameter]
    public Color ValueColor { get; set; } = Color.Default;

    [Parameter]
    public string? ChipText { get; set; }

    [Parameter]
    public Color ChipColor { get; set; } = Color.Default;

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public string? Class { get; set; }
}