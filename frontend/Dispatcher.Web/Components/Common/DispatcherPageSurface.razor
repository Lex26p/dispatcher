<div class="@RootClass">
    @ChildContent
</div>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? Class { get; set; }

    private string RootClass =>
        string.IsNullOrWhiteSpace(Class)
            ? "dispatcher-page-surface"
            : $"dispatcher-page-surface {Class}";
}