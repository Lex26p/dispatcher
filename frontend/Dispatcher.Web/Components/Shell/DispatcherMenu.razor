@inject NavigationManager Navigation

<div class="dispatcher-dropdown">
    <MudButton Variant="Variant.Text"
               Color="Color.Inherit"
               EndIcon="@Icons.Material.Filled.ArrowDropDown"
               Class="dispatcher-menu-button"
               OnClick="ToggleMenu">
        Диспетчер
    </MudButton>

    @if (_open)
    {
        <div class="dispatcher-dropdown-panel dispatcher-main-menu-panel">
            <div class="dispatcher-dropdown-section-title">
                Основные разделы
            </div>

            <button type="button" class="dispatcher-dropdown-item" @onclick='() => Go("/")'>
                Обзор системы
            </button>

            <button type="button" class="dispatcher-dropdown-item" @onclick='() => Go("/objects")'>
                Объекты
            </button>

            <button type="button" class="dispatcher-dropdown-item" @onclick='() => Go("/alarms")'>
                Аварии
            </button>

            <button type="button" class="dispatcher-dropdown-item" @onclick='() => Go("/history")'>
                История / Графики / Отчеты
            </button>

            <button type="button" class="dispatcher-dropdown-item" @onclick='() => Go("/configuration")'>
                Конфигурация
            </button>

            <button type="button" class="dispatcher-dropdown-item" @onclick='() => Go("/design")'>
                Дизайн
            </button>

            <button type="button" class="dispatcher-dropdown-item" @onclick='() => Go("/automation")'>
                Автоматизация
            </button>

            <div class="dispatcher-dropdown-divider"></div>

            <div class="dispatcher-dropdown-section-title">
                Служебные страницы
            </div>

            <button type="button" class="dispatcher-dropdown-item" @onclick='() => Go("/runtime")'>
                Runtime
            </button>

            <button type="button" class="dispatcher-dropdown-item" @onclick='() => Go("/health")'>
                Health
            </button>

            <button type="button" class="dispatcher-dropdown-item" @onclick='() => Go("/api-diagnostics")'>
                API-диагностика
            </button>
        </div>
    }
</div>

@code {
    private bool _open;

    private void ToggleMenu()
    {
        _open = !_open;
    }

    private void Go(string url)
    {
        _open = false;
        Navigation.NavigateTo(url);
    }
}