@page "/admin/settings"
@page "/admin/users"
@page "/admin/notifications"
@page "/admin/terminals"
@page "/admin/health"
@page "/admin/data-quality"
@page "/admin/audit"

<PageTitle>Системные настройки</PageTitle>

<section class="page-grid">
    <div class="page-title-row">
        <div>
            <h1>Системные настройки</h1>
            <p>Административная область отделена от личных `/settings/*`.</p>
        </div>

        <div class="live-chip">Admin</div>
    </div>

    <div class="metric-grid">
        <article class="metric-card">
            <span>Платформа</span>
            <strong>Healthy</strong>
            <small>Есть informational warnings</small>
        </article>

        <article class="metric-card">
            <span>Права</span>
            <strong>Effective</strong>
            <small>Роль, область, источник</small>
        </article>

        <article class="metric-card">
            <span>Терминалы</span>
            <strong>4</strong>
            <small>Device identity отдельно</small>
        </article>

        <article class="metric-card">
            <span>Аудит</span>
            <strong>Read-only</strong>
            <small>Не редактируется</small>
        </article>
    </div>

    <div class="content-grid">
        <article class="panel-card large">
            <div class="panel-card-header">
                <div>
                    <h2>Административная сводка</h2>
                    <p>Effective permissions без плоской матрицы checkbox; изменение после impact preview.</p>
                </div>
            </div>

            <div class="compact-list">
                <div>Последний администратор области защищён от снятия роли.</div>
                <div>Качество данных, occurrence и технический аудит — разные сущности.</div>
                <div>Endpoint диагностики маскируется, секреты не отображаются.</div>
                <div>Kiosk-профили и device identity будут развиваться отдельно.</div>
            </div>
        </article>

        <article class="panel-card">
            <div class="panel-card-header">
                <div>
                    <h2>Разделы admin</h2>
                    <p>Прямые маршруты</p>
                </div>
            </div>

            <div class="quick-links">
                <a href="/admin/users">Пользователи и роли</a>
                <a href="/admin/terminals">Терминалы</a>
                <a href="/admin/health">Состояние платформы</a>
                <a href="/admin/data-quality">Качество данных</a>
                <a href="/admin/audit">Аудит</a>
            </div>
        </article>
    </div>
</section>
