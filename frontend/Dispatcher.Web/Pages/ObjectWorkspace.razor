    protected override void OnParametersSet()
    {
        if (CurrentObject is null)
        {
            ShellState.SetPageTitle("Объект не найден");
            ShellState.SetControlModeAvailable(false);
            return;
        }

        _activeSection = NormalizeSectionQuery(SectionQuery);

        if (_activeSection == "Обзор")
        {
            _activeScreen = NormalizeScreenQuery(ScreenQuery);

            if (!Screens.Contains(_activeScreen))
            {
                _activeScreen = Screens.First();
            }
        }
        else if (!Screens.Contains(_activeScreen))
        {
            _activeScreen = Screens.First();
        }

        ShellState.SetPageTitle(CurrentObject.Name);
        ShellState.SetActiveAlarmCount(MockData.GetActiveAlarms().Count);
        ShellState.SetControlModeAvailable(!CurrentObject.IsSystemObject);
    }

    private void SelectSection(string section)
    {
        _activeSection = section;
        NavigateToCurrentObject(section, _activeScreen);
    }

    private void SelectScreen(string screen)
    {
        _activeSection = "Обзор";
        _activeScreen = screen;
        NavigateToCurrentObject("Обзор", screen);
    }

    private void SelectAlarmsSection()
    {
        SelectSection("Аварии");
    }

    private void SelectHistorySection()
    {
        SelectSection("История");
    }

    private void SelectDevicesSection()
    {
        SelectSection("Устройства");
    }

    private void SelectWidgetsSection()
    {
        SelectSection("Виджеты");
    }

    private void NavigateToCurrentObject(string section, string screen)
    {
        if (CurrentObject is null)
        {
            return;
        }

        var sectionValue = ToSectionQueryValue(section);

        if (section == "Обзор")
        {
            var screenValue = ToScreenQueryValue(screen);
            Navigation.NavigateTo($"/objects/{CurrentObject.Id}?section={sectionValue}&screen={screenValue}", replace: true);
            return;
        }

        Navigation.NavigateTo($"/objects/{CurrentObject.Id}?section={sectionValue}", replace: true);
    }

