@page "/me"
@page "/users/{UserId}"

<PageTitle>@Title</PageTitle>

<section class="page-grid">
    <div class="page-title-row">
        <div>
            <h1>@Title</h1>
            <p>Рабочая идентичность сотрудника. Видимость вычисляется для текущего зрителя.</p>
        </div>

        <div class="live-chip">Online</div>
    </div>

    <div class="content-grid">
        <article class="panel-card large">
            <div class="panel-card-header">
                <div>
                    <h2>Алексей Смирнов</h2>
                    <p>Дежурный диспетчер · Служба эксплуатации · Главный комплекс</p>
                </div>
            </div>

            <div class="compact-list">
                <div>Статус: Доступен до конца смены</div>
                <div>Ответственность: Корпуса A и B, Диспетчер событий, Передача смены</div>
                <div>Квалификация: III группа по электробезопасности</div>
                <div>Предпочтительный контакт: рабочий телефон</div>
            </div>
        </article>

        <article class="panel-card">
            <div class="panel-card-header">
                <div>
                    <h2>Закреплённое</h2>
                    <p>Только доступные рабочие материалы</p>
                </div>
            </div>

            <div class="quick-links">
                <a href="/d/main/overview">Климат · Корпус A</a>
                <a href="/my-work">Моя работа</a>
                <a href="/settings/profile">Настройки профиля</a>
                <a href="/settings/privacy">Видимость</a>
            </div>
        </article>
    </div>
</section>

@code {
    [Parameter]
    public string? UserId { get; set; }

    private string Title => string.IsNullOrWhiteSpace(UserId) ? "Моя страница" : $"Страница сотрудника · {UserId}";
}
