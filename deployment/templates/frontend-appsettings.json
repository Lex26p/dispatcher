{
  "schemaVersion": 1,
  "application": {
    "name": "dispatcher",
    "component": "frontend",
    "environment": "local-package",
    "versionTag": "v1.8.0-service-packaging"
  },
  "DispatcherApi": {
    "BaseUrl": "http://127.0.0.1:18080",
    "BaseAddress": "http://127.0.0.1:18080",
    "TimeoutSeconds": 10,
    "HealthEndpoint": "/health",
    "ReadinessEndpoint": "/ready",
    "RuntimeEndpoint": "/api/v1/runtime",
    "AlarmsEndpoint": "/api/v1/alarms"
  },
  "Features": {
    "ShowDashboard": true,
    "ShowHealth": true,
    "ShowRuntime": true,
    "ShowAlarms": true,
    "ShowApiDiagnostics": true,
    "ShowAuthAuditDiagnostics": false,
    "ShowNotificationDiagnostics": false
  },
  "Deployment": {
    "PackageMode": true,
    "StaticAssetsRoot": "wwwroot",
    "BackendStartScript": "scripts/Start-DispatcherBackend.ps1",
    "PackageSmokeScript": "scripts/Test-DispatcherPackage.ps1"
  }
}